# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Comma-separated list of allowed Telegram chat IDs
# Send /start to the bot to find your chat ID
ALLOWED_CHAT_IDS=123456789

# Default working directory for Claude and shell commands
DEFAULT_CWD=H:\ClaudePhone

# Default Claude model
DEFAULT_MODEL=sonnet

# Timeout for Claude commands in seconds
CLAUDE_TIMEOUT=300

# Timeout for shell commands in seconds
SHELL_TIMEOUT=60

# Max budget per Claude request in USD
MAX_BUDGET_USD=1.0
